# 実労働データ連携用の認証情報（取得後にコピーして .env として使用）
#   cp .env.example .env
# いずれも無料登録で取得できます。設定された分だけ enrich-labor が有効化されます。

# gBizINFO（経済産業省 法人情報API）: 従業員数・女性活躍情報（平均勤続年数・女性管理職比率・育休取得率 など）
#   取得: https://info.gbiz.go.jp/api/index.html
GBIZINFO_TOKEN=

# 職場情報総合サイト「しょくばらぼ」（厚労省）: 平均残業時間・有給取得率・離職率 の一括CSV
#   取得: https://shokuba.mhlw.go.jp/ の一括ダウンロードCSVのローカルパスを指定
SHOKUBA_CSV=

# EDINET（金融庁 有価証券報告書API v2）: 平均年間給与・平均勤続年数・平均年齢（上場企業）
#   取得: https://api.edinet-fsa.go.jp/api/auth/index.aspx?mode=1
EDINET_API_KEY=
